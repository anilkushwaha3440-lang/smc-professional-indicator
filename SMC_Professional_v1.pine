//@version=6
indicator(
     title = "SMC Professional v1",
     shorttitle = "SMC Pro",
     overlay = true,
     max_lines_count = 500,
     max_labels_count = 500,
     max_boxes_count = 500)

//====================================================
// INPUTS
//====================================================

groupStructure = "Market Structure"

showSwing =
     input.bool(
     true,
     "Show Swing Points",
     group = groupStructure)

showBOS =
     input.bool(
     true,
     "Show BOS",
     group = groupStructure)

showCHOCH =
     input.bool(
     true,
     "Show CHoCH",
     group = groupStructure)

showMSS =
     input.bool(
     true,
     "Show MSS",
     group = groupStructure)

swingLength =
     input.int(
     5,
     "Swing Length",
     minval = 2,
     maxval = 20,
     group = groupStructure)

//====================================================
// COLORS
//====================================================

bullColor =
     color.rgb(0,180,90)

bearColor =
     color.rgb(220,50,50)

neutralColor =
     color.gray

textColor =
     color.white

//====================================================
// ENUMS
//====================================================

enum Trend

    Bull

    Bear

    Neutral

//====================================================
// TYPES
//====================================================

type Swing

    float price

    int index

    bool broken

    bool strong

//====================================================
// GLOBAL VARIABLES
//====================================================

var Trend trend = Trend.Neutral

var Swing externalHigh =
     Swing.new(na,na,false,false)

var Swing externalLow =
     Swing.new(na,na,false,false)

var Swing internalHigh =
     Swing.new(na,na,false,false)

var Swing internalLow =
     Swing.new(na,na,false,false)
//====================================================
// UTILITY FUNCTIONS
//====================================================

// Is bullish candle
isBullish() =>
    close > open

// Is bearish candle
isBearish() =>
    close < open

// Candle body size
bodySize() =>
    math.abs(close - open)

// Full candle range
candleRange() =>
    high - low

// Mid price
midPrice(float h, float l) =>
    (h + l) * 0.5

// Tick adjusted comparison
greaterThan(float a, float b) =>
    a > b + syminfo.mintick

lessThan(float a, float b) =>
    a < b - syminfo.mintick

equalPrice(float a, float b, float tolerance) =>
    math.abs(a - b) <= tolerance

//====================================================
// DRAWING FUNCTIONS
//====================================================

drawLabel(
    int x,
    float y,
    string txt,
    color bg,
    label_style style)=>

    label.new(
         x = x,
         y = y,
         text = txt,
         color = bg,
         style = style,
         textcolor = textColor,
         size = size.small)

drawHorizontal(
    int x1,
    float y,
    color clr)=>

    line.new(
         x1 = x1,
         y1 = y,
         x2 = bar_index,
         y2 = y,
         color = clr,
         width = 2)

//====================================================
// SWING STORAGE HELPERS
//====================================================

updateSwing(
    Swing swing,
    float price,
    int index)=>

    swing.price := price
    swing.index := index
    swing.broken := false
    swing.strong := false

markBroken(
    Swing swing)=>

    swing.broken := true

markStrong(
    Swing swing)=>

    swing.strong := true
//====================================================
// SWING ENGINE
//====================================================

// Confirmed swing points
pivotHigh = ta.pivothigh(high, swingLength, swingLength)
pivotLow  = ta.pivotlow(low, swingLength, swingLength)

// Last confirmed pivots
var float lastPivotHigh = na
var float lastPivotLow  = na

if not na(pivotHigh)

    lastPivotHigh := pivotHigh

    updateSwing(
         externalHigh,
         pivotHigh,
         bar_index - swingLength)

    if showSwing

        drawLabel(
             bar_index - swingLength,
             pivotHigh,
             "SH",
             color.orange,
             label.style_label_down)

if not na(pivotLow)

    lastPivotLow := pivotLow

    updateSwing(
         externalLow,
         pivotLow,
         bar_index - swingLength)

    if showSwing

        drawLabel(
             bar_index - swingLength,
             pivotLow,
             "SL",
             color.aqua,
             label.style_label_up)
//====================================================
// STRUCTURE CLASSIFICATION
//====================================================

var float previousHigh = na
var float previousLow  = na

bool isHH = false
bool isLH = false
bool isHL = false
bool isLL = false

if not na(pivotHigh)

    isHH := na(previousHigh) or pivotHigh > previousHigh
    isLH := not isHH

    previousHigh := pivotHigh

if not na(pivotLow)

    isLL := na(previousLow) or pivotLow < previousLow
    isHL := not isLL

    previousLow := pivotLow
if showSwing

    if isHH

        drawLabel(
             bar_index - swingLength,
             pivotHigh,
             "HH",
             bullColor,
             label.style_label_down)

    if isLH

        drawLabel(
             bar_index - swingLength,
             pivotHigh,
             "LH",
             bearColor,
             label.style_label_down)

    if isHL

        drawLabel(
             bar_index - swingLength,
             pivotLow,
             "HL",
             bullColor,
             label.style_label_up)

    if isLL

        drawLabel(
             bar_index - swingLength,
             pivotLow,
             "LL",
             bearColor,
             label.style_label_up)
//====================================================
// BREAK OF STRUCTURE (BOS)
//====================================================

// Bullish BOS
bullishBos =
    not na(externalHigh.price) and
    not externalHigh.broken and
    close > externalHigh.price

// Bearish BOS
bearishBos =
    not na(externalLow.price) and
    not externalLow.broken and
    close < externalLow.price

//------------------------------
// Bullish BOS
//------------------------------

if bullishBos

    markBroken(externalHigh)

    trend := Trend.Bull

    if showBOS

        drawHorizontal(
             externalHigh.index,
             externalHigh.price,
             bullColor)

        drawLabel(
             bar_index,
             externalHigh.price,
             "BOS",
             bullColor,
             label.style_label_up)

//------------------------------
// Bearish BOS
//------------------------------

if bearishBos

    markBroken(externalLow)

    trend := Trend.Bear

    if showBOS

        drawHorizontal(
             externalLow.index,
             externalLow.price,
             bearColor)

        drawLabel(
             bar_index,
             externalLow.price,
             "BOS",
             bearColor,
             label.style_label_down)
//====================================================
// TREND STATE
//====================================================

bgcolor(
 trend == Trend.Bull ?
 color.new(bullColor,95) :

 trend == Trend.Bear ?
 color.new(bearColor,95) :

 na)
